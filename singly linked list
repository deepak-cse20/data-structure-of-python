class Node:
    def __init__(self,music):
        self.music = music
        self.next = None

class PlayList:
    def __init__(self):
        self.head = None

    def is_empty (self):
        return self.head is None

    def append(self, music):
        new_node = Node(music)
        if self.head is None:
            self.head = new_node
            return
        current = self.head
        while current.next:
            current = current.next
        current.next = new_node

    def prepend(self,music):
        new_node = Node(music)
        new_node.next = self.head
        self.head = new_node

    def insert(self,music,pos):
        new_node = Node(music)
        current = self.head
        while current:
            if (current.music == pos):
                new_node.next = current.next
                current.next = new_node
            current = current.next
        return

    def delete(self,music):
        if self.head is None:
            return
        if self.head.music == music:
            self.head = self.head.next
            return
        current = self.head
        while current.next:
            if current.next.music == music:
                current.next = current.next.next
                return
            current = current.next

    def search(self,music):
        current = self.head
        while current:
            if current.music == music:
                return True
            current = current.next
        return False

    def display(self):
        current = self.head
        while current:
            print(current.music , end = "\n")
            current = current.next

if __name__ == '__main__':

    playlist = PlayList()

    pos = input("Enter the song after which the new song should be added")
    music = input("Enter the song name to add")

    Music = input("Enter the music to be searched")

    song = input("Enter song to delete") 

    print("==== PLAYLIST ===")
    playlist.append("Sunflower")
    playlist.append("sad")
    playlist.append("Starboy")
    playlist.append("timeless")

    playlist.prepend("cryforme")
    playlist.prepend("moonlight")

    playlist.insert(music,pos)

    playlist.delete(song)

    a = playlist.search(Music)
    if a == True:
        print("Song Present")
    else:
        print("Song Not Found")

    playlist.display()

        

        
